{
    "niri/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "urgent": "",
            "active": "",
            "default": ""
        },
    },
    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 18,
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close"
    },
    "niri/window": {
        "rewrite": {
            "(.*) - Google Chrome": "яЙи $1",
            "(.*) тАФ Mozilla Firefox": "яЙй $1"
        },
        "separate-outputs": true,
        "max-length": 50
    },
    "custom/updates": {
        "format": "яВл  {}",
        "tooltip-format": "{}",
        "escape": true,
        "return-type": "json",
        "exec": "updates",
        "restart-interval": 60,
        "on-click-middle": "launch $TERMINAL -e installupdates",
        "tooltip": true
    },
    "custom/outlook": {
        "format": "яГа",
        "on-click": "launch firefox --new-window https://outlook.office.com/mail/",
        "tooltip": false
    },
    "custom/browser": {
        "format": "яЙй",
        "on-click": "launch firefox",
        "tooltip": false
    },
    "custom/chatgpt": {
        "format": "яГл",
        "on-click": "launch firefox --new-window https://chat.openai.com",
        "tooltip": false
    },
    "custom/appmenu": {
        "format": "яАВ",
        "on-click": "sleep 0.1 && launch rofi -show",
        "tooltip": false
    },
    "custom/exit": {
        "format": "яАС",
        "on-click": "wlogout",
        "tooltip": false
    },
    "tray": {
        "spacing": 10
    },
    "clock": {
        "tooltip-format": "<tt>{calendar}</tt>",
        "calendar": {
            "mode": "month",
            "mode-mon-col": 3,
            "on-scroll": 1,
            "on-click-right": "mode",
            "format": {
                "months": "<span color='#ffead3'><b>{}</b></span>",
                "days": "<span color='#ecc6d9'><b>{}</b></span>",
                "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
                "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
                "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
            }
        },
        "actions": {
            "on-click-right": "mode",
            "on-click-forward": "tz_up",
            "on-click-backward": "tz_down",
            "on-scroll-up": "shift_down",
            "on-scroll-down": "shift_up"
        },
        "format-alt": "{:%Y-%m-%d}"
    },
    "cpu": {
        "interval": 2,
        "format": "/ яЛЫ {usage}% ",
        "states": {
            "warning": 50,
            "critical": 80
        },
        "on-click-middle": "launch missioncenter"
    },
    "memory": {
        "interval": 2,
        "format": "/ яФ╕ {percentage}% ",
        "tooltip-format": "{used:0.1f}G/{total:0.1f}G",
        "states": {
            "warning": 80,
            "critical": 90
        },
        "on-click-middle": "launch missioncenter"
    },
    "disk": {
        "interval": 30,
        "format": "яВа {percentage_used}% ",
        "path": "/",
        "on-click-middle": "launch missioncenter"
    },
    "network": {
        "interval": 2,
        "format": "{ifname}",
        "format-wifi": "яЗл {signalStrength}%",
        "format-alt": "яГШ {bandwidthUpBytes} яГЧ {bandwidthDownBytes}",
        "format-ethernet": "яЮЦ {ipaddr}",
        "format-disconnected": "яДз", //An empty format will hide the module.
        "tooltip-format": "ifname: {ifname}\nessid: {essid}\nip: {ipaddr}/{cidr}\nspeed: яГШ {bandwidthUpBytes} яГЧ {bandwidthDownBytes}",
        "tooltip-format-disconnected": "",
        "on-click-middle": "launch nm-applet"
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "яЧз {capacity}%",
        "format-plugged": "яЗж {capacity}%",
        "format-alt": "{icon}  {time}",
        "format-icons": [
            "яЙД ",
            "яЙГ ",
            "яЙВ ",
            "яЙБ ",
            "яЙА "
        ]
    },
    "pulseaudio": {
        "scroll-step": 2,
        "format": "{icon} {volume}%",
        "format-bluetooth": "{volume}% {icon} яКФ",
        "format-bluetooth-muted": "яЪй яКФ",
        "format-muted": "яЪй",
        "format-source": "яД░ {volume}%",
        "format-source-muted": "яД▒",
        "format-icons": {
            "headphone": "яАе",
            "hands-free": "яКа",
            "headset": "яЦР",
            "phone": "яВХ",
            "portable": "яПО",
            "car": "яЖ╣",
            "default": [
                "яАж",
                "яАи ",
                "яАи "
            ]
        },
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "on-click-middle": "launch pavucontrol"
    },
    "backlight": {
        "format": "{icon} {percent}%",
        "format-icons": [
            "юОН",
            "юПУ",
            "юПС",
            "юПП",
            "юПО",
            "юПН",
            "юПК",
            "юПИ",
            "юОЫ"
        ]
    },
    "temperature": {
        "critical-threshold": 80,
        "format": "/ {icon} {temperatureC}┬░C ",
        "format-icons": [
            "яЛЛ",
            "яЛК",
            "яЛЙ",
            "яЛИ",
            "яЛЗ"
        ],
        "on-click-middle": "launch missioncenter"
    },
    "user": {
        "format": "{user}",
        "interval": 60,
        "icon": false
    },
    "custom/notification": {
        "tooltip": false,
        "format": "{icon}",
        "format-icons": {
          "notification": "яВв<span foreground='red'><sup>яСД</sup></span>",
          "none": "яВв",
          "dnd-notification": "яЗ╖<span foreground='red'><sup>яСД</sup></span>",
          "dnd-none": "яЗ╖",
          "inhibited-notification": "яВв<span foreground='red'><sup>яСД</sup></span>",
          "inhibited-none": "яВв",
          "dnd-inhibited-notification": "яЗ╖<span foreground='red'><sup>яСД</sup></span>",
          "dnd-inhibited-none": "яЗ╖"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    }
}
