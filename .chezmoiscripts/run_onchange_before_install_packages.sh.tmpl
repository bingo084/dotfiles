{{- define "install_packages" -}}
  {{- $pkg := list -}}
  {{- $deps := list -}}
  {{- $installed := .installed -}}

  {{- range .packages -}}
    {{- if kindIs "string" . -}}
      {{- if not (has . $installed) -}}
        {{- $pkg = append $pkg . -}}
      {{- end -}}

    {{- else if kindIs "map" . -}}
      {{- if not (has .name $installed) -}}
        {{- $pkg = append $pkg .name -}}
      {{- end -}}

      {{- /* deps = [...] or deps = "pkg" — install as dependencies (--asdeps) */ -}}
      {{- if hasKey . "deps" -}}
        {{- if kindIs "string" .deps -}}
          {{- if not (has .deps $installed) -}}
            {{- $deps = append $deps .deps -}}
          {{- end -}}
        {{- else -}}
          {{- range .deps -}}
            {{- if kindIs "string" . -}}
              {{- if not (has . $installed) -}}
                {{- $deps = append $deps . -}}
              {{- end -}}
            {{- else if kindIs "map" . -}}
              {{- if not (has .name $installed) -}}
                {{- $deps = append $deps .name -}}
              {{- end -}}
            {{- end -}}
          {{- end -}}
        {{- end -}}
      {{- end -}}

      {{- /* packages = [...] — install as explicit (not --asdeps) */ -}}
      {{- if hasKey . "packages" -}}
        {{- range .packages -}}
          {{- if kindIs "string" . -}}
            {{- if not (has . $installed) -}}
              {{- $pkg = append $pkg . -}}
            {{- end -}}
          {{- else if kindIs "map" . -}}
            {{- if not (has .name $installed) -}}
              {{- $pkg = append $pkg .name -}}
            {{- end -}}
          {{- end -}}
        {{- end -}}
      {{- end -}}

    {{- end -}}
  {{- end -}}

  {{- if $pkg }}
paru -S --noconfirm --needed {{ join " " $pkg }}
  {{- end -}}
  {{- if $deps }}
paru -S --noconfirm --needed --asdeps {{ join " " $deps }}
  {{- end -}}
{{- end -}}

{{- if and (eq .chezmoi.os "linux") (eq .chezmoi.osRelease.id "arch") -}}
#!/bin/bash

if [ "$CHEZMOI_COMMAND" = "init" ]; then
  echo ":: Updating system"
  sudo pacman -Syu --noconfirm
fi
{{ $installed := splitList "\n" (output "pacman" "-Qq") }}
echo ":: Installing packages"
{{- template "install_packages" (dict "packages" .packages.arch "installed" $installed) }}
echo ":: Done"
{{- end -}}
